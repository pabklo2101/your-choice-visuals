<!-- ABOUT -->
<section id="about">
  <div class="about-grid">
    <div class="about-visual fade-in" style="position:relative;padding-bottom:48px;">
      <div class="about-card-main">
        <h3>Our Vision</h3>
        <p>To be the most trusted visibility partner for small and medium enterprises in Lesotho — providing practical, affordable, and results‑driven marketing and advertising services that enhance visibility, strengthen brands, and drive sustainable growth.</p>
