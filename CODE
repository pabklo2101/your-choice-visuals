<script>
  function showArm(armId, btn) {
    document.querySelectorAll('.arm-section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.arm-tab').forEach(t => t.classList.remove('active'));
    document.getElementById(armId).classList.add('active');
    if(btn) btn.classList.add('active');
  }

  function scrollToContact() {
    document.getElementById('contact').scrollIntoView({behavior:'smooth'});
  }

  function submitForm() {
    document.getElementById('form-wrap').style.display = 'none';
    document.getElementById('form-success').style.display = 'block';
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

  window.addEventListener('scroll', () => {
    document.querySelector('nav').style.boxShadow = window.scrollY > 40 ? '0 4px 24px rgba(0,0,0,0.3)' : 'none';
  });
</script>
