  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; margin-top: 60px; }
  .about-card-main { background: linear-gradient(145deg, var(--deep-blue), var(--blue)); border-radius: 24px; padding: 48px 40px; color: white; position: relative; overflow: hidden; }
  .about-card-main::before { content: ''; position: absolute; top: -40px; right: -40px; width: 200px; height: 200px; background: radial-gradient(circle, rgba(88,214,141,0.2), transparent 70%); border-radius: 50%; }
  .about-card-main h3 { font-size: 1.4rem; font-weight: 800; margin-bottom: 16px; color: var(--lime); }
  .about-card-main p { font-size: 0.95rem; line-height: 1.8; color: rgba(255,255,255,0.8); }
