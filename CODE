  .value-item h4 { font-size: 0.9rem; font-weight: 700; color: var(--text-dark); margin-bottom: 4px; }
  .value-item p { font-size: 0.82rem; color: var(--text-soft); line-height: 1.6; }

  /* SERVICES */
  #services { background: var(--white); }
  .services-intro { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 60px; flex-wrap: wrap; gap: 24px; }
  .arm-tabs { display: flex; gap: 10px; flex-wrap: wrap; }
  .arm-tab { padding: 10px 22px; border-radius: 50px; border: 1.5px solid var(--light-gray); background: transparent; cursor: pointer; font-family: 'Syne', sans-serif; font-size: 0.85rem; font-weight: 600; color: var(--text-soft); transition: all 0.25s; }
